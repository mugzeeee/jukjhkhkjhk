local function addLogRow(entry)
    logRowCount = logRowCount + 1
    local row = Instance.new("Frame")
    row.BackgroundTransparency = logRowCount % 2 == 0 and 0.9 or 1
    row.BackgroundColor3 = THEME.SidebarSelected
    row.BorderSizePixel = 0
    row.Size = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize = Enum.AutomaticSize.Y
    row.LayoutOrder = logRowCount
    row.Parent = logsScrollFrame
    local rPad = makePadding(row, 6)

    local timeStr = string.format("%02d:%02d:%02d", math.floor(entry.clock / 3600) % 24, math.floor(entry.clock / 60) % 60, math.floor(entry.clock) % 60)
    local prefix  = string.format("[%s][%s] ", timeStr, entry.level:upper())
    local fullText = prefix .. entry.message

    local lbl = makeTextLabel(row, fullText, 11, "semibold")
    lbl.TextColor3 = LOG_COLORS[entry.level] or LOG_COLORS.info
    lbl.TextWrapped = true
    lbl.Size = UDim2.new(1, 0, 0, 0)
    lbl.AutomaticSize = Enum.AutomaticSize.Y
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextYAlignment = Enum.TextYAlignment.Top

    -- Auto-scroll to bottom
    task.defer(function()
        logsScrollFrame.CanvasPosition = Vector2.new(0, math.max(0, logsScrollFrame.AbsoluteCanvasSize.Y - logsScrollFrame.AbsoluteSize.Y))
    end)
end

