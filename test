            MaxMessagesPerSecond = ClientSettings.MaxMessagesPerSecond,
            MaxQueuePerUser = ClientSettings.MaxQueuePerUser,
            AutoReply = ClientSettings.AutoReply,
            PerUserMemory = ClientSettings.PerUserMemory,
            BlacklistUserIds = ClientSettings.BlacklistUserIds,
            AdminUserIds = ClientSettings.AdminUserIds,
            FollowingEnabled = ClientSettings.FollowingEnabled,
            FollowMode = ClientSettings.FollowMode,
            ToggleKey = ClientSettings.ToggleKey and ClientSettings.ToggleKey.Name or nil,
        }
        local json = game:GetService("HttpService"):JSONEncode(data)
        writefile(SETTINGS_FILE, json)
    end)
    if not ok then
        -- writefile not available in this executor, silently ignore
    end
end

local function loadSettings()
    local ok, result = pcall(function()
        if not isfile(SETTINGS_FILE) then return end
        local json = readfile(SETTINGS_FILE)
        local data = game:GetService("HttpService"):JSONDecode(json)

        local function merge(src, dst)
            for k, v in pairs(src) do
                if type(v) == "table" and type(dst[k]) == "table" then
                    merge(v, dst[k])
                else
                    dst[k] = v
                end
            end
        end
        merge(data, ClientSettings)

        -- Restore ToggleKey from string
        if type(data.ToggleKey) == "string" then
            local ok2, kc = pcall(function()
                return Enum.KeyCode[data.ToggleKey]
            end)
            if ok2 and kc then
                ClientSettings.ToggleKey = kc
            end
        end
    end)
    if not ok then
        -- readfile/isfile not available or parse error, use defaults
    end
end

