-- ── Logger ────────────────────────────────────────────────────────────────
local Logger = (function()
    local MAX_ENTRIES = 200
    local entries = {}
    local listeners = {}

    local LEVELS = { debug = 1, info = 2, warn = 3, error = 4 }

    local function add(level, message)
        if not LEVELS[level] then level = "info" end
        local entry = {
            level   = level,
            message = tostring(message or ""),
            time    = os.time(),
            clock   = os.clock(),
        }
        table.insert(entries, entry)
        if #entries > MAX_ENTRIES then
            table.remove(entries, 1)
        end
        for _, fn in ipairs(listeners) do
            pcall(fn, entry)
        end
    end

    return {
        Add      = add,
        Entries  = function() return entries end,
        Clear    = function() entries = {} end,
        OnEntry  = function(fn) table.insert(listeners, fn) end,
        -- shorthand helpers
        Info     = function(msg) add("info",  msg) end,
        Warn     = function(msg) add("warn",  msg) end,
        Error    = function(msg) add("error", msg) end,
        Debug    = function(msg) add("debug", msg) end,
    }
end)()

