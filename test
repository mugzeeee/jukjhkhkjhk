local CharControl = {}

-- ── Internal state ────────────────────────────────────────────────────────
local _followTarget      = nil   -- Player object being followed
local _followConnection  = nil   -- RunService heartbeat for following
local _orbitTarget       = nil
local _orbitConnection   = nil
local _orbitAngle        = 0
local _killLoopTarget    = nil
local _killLoopActive    = false

-- ── Helpers ───────────────────────────────────────────────────────────────
local PathfindingService = game:GetService("PathfindingService")

local function getRootOf(p)
    local char = (type(p) == "userdata" and p.Character) or p
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoidOf(p)
    local char = (type(p) == "userdata" and p.Character) or p
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getMyRoot()
    return LocalRoot or (LocalCharacter and LocalCharacter:FindFirstChild("HumanoidRootPart"))
end

local function moveTo(targetPos)
    local hum = getHumanoidOf(LocalCharacter)
    if hum then
        hum:MoveTo(targetPos)
    end
end

local function pathfindTo(targetPos)
    local myRoot = getMyRoot()
    if not myRoot then return end
    local hum = getHumanoidOf(LocalCharacter)
    if not hum then return end

    local path = PathfindingService:CreatePath({
        AgentRadius = 2,
        AgentHeight = 5,
        AgentCanJump = true,
    })

    local ok = pcall(function()
        path:ComputeAsync(myRoot.Position, targetPos)
    end)
    if not ok or path.Status ~= Enum.PathStatus.Success then
        -- Fall back to linear
        hum:MoveTo(targetPos)
        return
    end

    local waypoints = path:GetWaypoints()
    for _, wp in ipairs(waypoints) do
        if wp.Action == Enum.PathWaypointAction.Jump then
            hum.Jump = true
        end
        hum:MoveTo(wp.Position)
        local reached = hum.MoveToFinished:Wait(2)
        if not reached then break end
    end
end

-- ── Follow ────────────────────────────────────────────────────────────────
local function _stopFollowInternal()
    if _followConnection then
        _followConnection:Disconnect()
        _followConnection = nil
    end
    _followTarget = nil
end

local function _startFollow(targetPlayer)
    _stopFollowInternal()
    _followTarget = targetPlayer
    Logger:Add("info", "[Follow] Following " .. tostring(targetPlayer.Name))

    local lastPathTime = 0
    local PATH_INTERVAL = 1.5   -- re-path every 1.5 s for Pathfinding mode
    local LINEAR_DIST   = 4     -- stop walking when closer than 4 studs

    _followConnection = RunService.Heartbeat:Connect(function()
        if not _followTarget or not _followTarget.Parent then
            _stopFollowInternal()
            return
        end
        local myRoot  = getMyRoot()
        local tgtRoot = getRootOf(_followTarget)
        if not myRoot or not tgtRoot then return end

        local dist = (myRoot.Position - tgtRoot.Position).Magnitude
        if dist < LINEAR_DIST then return end

        local now = os.clock()
        if ClientSettings.FollowMode == "Pathfinding" then
            if (now - lastPathTime) >= PATH_INTERVAL then
                lastPathTime = now
                task.spawn(pathfindTo, tgtRoot.Position)
            end
        else
            moveTo(tgtRoot.Position)
        end
    end)
end

requestFollow = function(targetPlayer)
    Stats.FollowRequests = Stats.FollowRequests + 1
    Logger:Add("info", "[Follow] Request from " .. tostring(targetPlayer.Name))
    _startFollow(targetPlayer)
    if pushNotification then
        pushNotification("Following", "Now following " .. tostring(targetPlayer.DisplayName), THEME and THEME.Accent or nil)
    end
end

stopFollow = function(targetPlayer)
    Stats.StopRequests = Stats.StopRequests + 1
    if _followTarget then
        Logger:Add("info", "[Follow] Stopped following " .. tostring(_followTarget.Name))
    end
    _stopFollowInternal()
    -- Stop movement
    local hum = getHumanoidOf(LocalCharacter)
    if hum then
        local myRoot = getMyRoot()
        if myRoot then hum:MoveTo(myRoot.Position) end
    end
end

-- ── Orbit ─────────────────────────────────────────────────────────────────
function CharControl.startOrbit(targetPlayer, radius, speed)
    if _orbitConnection then _orbitConnection:Disconnect() end
    _orbitTarget = targetPlayer
    _orbitAngle  = 0
    radius = radius or 8
    speed  = speed  or 1.2

    Logger:Add("info", "[Orbit] Orbiting " .. tostring(targetPlayer.Name))

    _orbitConnection = RunService.Heartbeat:Connect(function(dt)
        if not _orbitTarget or not _orbitTarget.Parent then
            _orbitConnection:Disconnect()
            _orbitConnection = nil
            return
        end
        local tgtRoot = getRootOf(_orbitTarget)
        if not tgtRoot then return end

        _orbitAngle = _orbitAngle + speed * dt
        local offset = Vector3.new(
            math.cos(_orbitAngle) * radius,
            0,
            math.sin(_orbitAngle) * radius
        )
        local dest = tgtRoot.Position + offset
        moveTo(dest)
    end)
end

function CharControl.stopOrbit()
    if _orbitConnection then
        _orbitConnection:Disconnect()
        _orbitConnection = nil
    end
    _orbitTarget = nil
end

-- ── Kill loop (spam jump + tool activate near target) ─────────────────────
function CharControl.startKillLoop(targetPlayer)
    if _killLoopActive then return end
    _killLoopActive = true
    _killLoopTarget = targetPlayer
    Logger:Add("warn", "[KillLoop] Started on " .. tostring(targetPlayer.Name))

    task.spawn(function()
        while _killLoopActive do
            local myRoot  = getMyRoot()
            local tgtRoot = getRootOf(_killLoopTarget)
            if not myRoot or not tgtRoot or not _killLoopTarget.Parent then
                break
            end

            -- Move toward target
            moveTo(tgtRoot.Position)

            -- Try to activate held tool
            local char = LocalCharacter
            if char then
                local tool = char:FindFirstChildOfClass("Tool")
                if tool and tool:FindFirstChildOfClass("RemoteEvent") then
                    pcall(function()
                        local mouse = player:GetMouse()
                        tool:Activate()
                    end)
                end
            end

            task.wait(0.1)
        end
        _killLoopActive = false
        _killLoopTarget = nil
        Logger:Add("info", "[KillLoop] Stopped")
    end)
end

function CharControl.stopKillLoop()
    _killLoopActive = false
    _killLoopTarget = nil
end

-- ── processp6x20xxCommandFunc – chat command interceptor ──────────────────
--   Handles owner/admin commands typed in chat (prefix: /p)
local function processp6x20xxCommandFunc(senderPlayer, rawMsg)
    local msg = rawMsg:lower():gsub("^%s+", "")

    -- Only process commands from AdminUserIds or server owner
    local isAdmin = false
    if senderPlayer.UserId == Players.LocalPlayer.UserId then
        isAdmin = true  -- self is always admin
    end
    for _, id in ipairs(ClientSettings.AdminUserIds or {}) do
        if id == senderPlayer.UserId then
            isAdmin = true
            break
        end
    end
    if not isAdmin then return false end

    -- /p follow <name>
    local followTarget = msg:match("^/p follow%s+(.+)$")
    if followTarget then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == followTarget:lower() or p.DisplayName:lower() == followTarget:lower() then
                requestFollow(p)
                return true
            end
        end
        return true
    end

    -- /p stop or /p unfollow
    if msg:match("^/p stop$") or msg:match("^/p unfollow$") then
        stopFollow(senderPlayer)
        return true
    end

    -- /p orbit <name> [radius] [speed]
    local orbitArgs = msg:match("^/p orbit%s+(.+)$")
    if orbitArgs then
        local parts = {}
        for w in orbitArgs:gmatch("%S+") do table.insert(parts, w) end
        local tname = parts[1]
        local radius = tonumber(parts[2]) or 8
        local speed  = tonumber(parts[3]) or 1.2
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == tname or p.DisplayName:lower() == tname then
                CharControl.startOrbit(p, radius, speed)
                return true
            end
        end
        return true
    end

    -- /p orbitstop
    if msg:match("^/p orbitstop$") then
        CharControl.stopOrbit()
        return true
    end

    -- /p kill <name>
    local killTarget = msg:match("^/p kill%s+(.+)$")
    if killTarget then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == killTarget:lower() then
                CharControl.startKillLoop(p)
                return true
            end
        end
        return true
    end

    -- /p killstop
    if msg:match("^/p killstop$") then
        CharControl.stopKillLoop()
        return true
    end

    -- /p tp <name>  – teleport to player
    local tpTarget = msg:match("^/p tp%s+(.+)$")
    if tpTarget then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name:lower() == tpTarget:lower() then
                local tgtRoot = getRootOf(p)
                local myRoot  = getMyRoot()
                if tgtRoot and myRoot then
                    local offset = tgtRoot.CFrame * CFrame.new(3, 0, 0)
                    pcall(function() myRoot.CFrame = offset end)
                end
                return true
            end
        end
        return true
    end

    -- /p speed <value>
    local speedVal = msg:match("^/p speed%s+(%d+)$")
    if speedVal then
        local hum = getHumanoidOf(LocalCharacter)
        if hum then
            hum.WalkSpeed = math.clamp(tonumber(speedVal) or 16, 0, 500)
        end
        return true
    end

    -- /p jump <value>
    local jumpVal = msg:match("^/p jump%s+(%d+)$")
    if jumpVal then
        local hum = getHumanoidOf(LocalCharacter)
        if hum then
            hum.JumpPower = math.clamp(tonumber(jumpVal) or 50, 0, 1000)
        end
        return true
    end

    -- /p reset
    if msg:match("^/p reset$") then
        local hum = getHumanoidOf(LocalCharacter)
        if hum then hum.Health = 0 end
        return true
    end

    -- /p save  – save settings to disk
    if msg:match("^/p save$") then
        saveSettings()
        return true
    end

    -- /p stats  – print session stats to logs
    if msg:match("^/p stats$") then
        Logger:Add("info", string.format(
            "[Stats] Recv=%d Reply=%d Errors=%d RLim=%d Uptime=%ds",
            Stats.MessagesReceived, Stats.MessagesReplied,
            Stats.ApiErrors, Stats.RateLimitHits, Stats:Uptime()
        ))
        return true
    end

    return false
end

-- Wire up the command interceptor into the existing chat pipeline
do
    local _origProcess = processChatMessage
    processChatMessage = function(p, rawMessage)
        -- Try command intercept first (admin-only prefix /p)
        if rawMessage:match("^/p ") or rawMessage:match("^/p$") then
            processp6x20xxCommandFunc(p, rawMessage)
            return
        end
        _origProcess(p, rawMessage)
    end
end


