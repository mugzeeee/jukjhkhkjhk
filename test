        TweenService:Create(inputStroke, TweenInfo.new(0.15), {
            Color = Color3.fromRGB(55, 55, 70), Transparency = 0,
        }):Play()
    end)

    -- Slide card in
    task.defer(function()
        TweenService:Create(card, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Position = UDim2.new(0.5, 0, 0.5, 0),
            BackgroundTransparency = 0,
        }):Play()
    end)

    -- ── Validation logic ──────────────────────────────────────────────────

    local checking = false

    local function setStatus(msg, color)
        statusLbl.Text = msg
        statusLbl.TextColor3 = color or KEY_ERR
    end

    local function shakeCard()
        task.spawn(function()
            local offsets = { -10, 10, -7, 7, -4, 4, 0 }
            for _, ox in ipairs(offsets) do
                card.Position = UDim2.new(0.5, ox, 0.5, 0)
                task.wait(0.04)
            end
            card.Position = UDim2.new(0.5, 0, 0.5, 0)
        end)
    end

    local function tryValidate()
        if checking then return end
        local raw = keyInput.Text:match("^%s*(.-)%s*$")
        if raw == "" then
            setStatus("Please enter a key.", KEY_ERR)
            shakeCard()
            return
        end

        checking = true
        unlockBtn.Text = "Checking..."
        unlockBtn.BackgroundTransparency = 0.45
        setStatus("Contacting key server...", KEY_DIM)

		task.spawn(function()
            local ok, result = pcall(function()
                -- Detect the executor's custom HTTP function
                local http_req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
                
                if http_req then
                    local response = http_req({
                        Url = KEY_VALIDATE_URL,
                        Method = "GET"
                    })
                    if response.StatusCode == 200 then
                        return response.Body or response.body
                    else
                        error("HTTP Status: " .. tostring(response.StatusCode))
                    end
                else
                    -- Fallback (will likely fail on client, but here just in case)
                    return HttpService:GetAsync(KEY_VALIDATE_URL, true)
                end
            end)

            if not ok then
                setStatus("Could not reach key server. Check executor HTTP access.", KEY_ERR)                shakeCard()
                unlockBtn.Text = "Unlock"
                unlockBtn.BackgroundTransparency = 0.1
                checking = false
                return
            end

            -- One key per line; lines beginning with # are comments
            local valid = false
            for line in result:gmatch("[^\r\n]+") do
                local trimmed = line:match("^%s*(.-)%s*$")
                if trimmed ~= "" and trimmed:sub(1,1) ~= "#" then
                    if trimmed == raw then
                        valid = true
                        break
                    end
                end
            end

            if valid then
                setStatus("Access granted!", KEY_OK)
                TweenService:Create(cardStroke, TweenInfo.new(0.3), {
                    Color = KEY_OK, Transparency = 0.2,
                }):Play()
                unlockBtn.Text = "✓ Unlocked"
                unlockBtn.BackgroundColor3 = KEY_OK
                unlockBtn.BackgroundTransparency = 0.05

                task.wait(0.65)

                TweenService:Create(card, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
                    Position = UDim2.new(0.5, 0, 0.35, 0),
                    BackgroundTransparency = 1,
                }):Play()
                TweenService:Create(backdrop, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
                    BackgroundTransparency = 1,
                }):Play()

                task.wait(0.5)
                keyGui:Destroy()
                showSelectionScreen()
            else
                setStatus("Invalid key. Check your key and try again.", KEY_ERR)
                shakeCard()
                TweenService:Create(cardStroke, TweenInfo.new(0.2), {
                    Color = KEY_ERR, Transparency = 0.3,
                }):Play()
                task.delay(1.5, function()
                    TweenService:Create(cardStroke, TweenInfo.new(0.3), {
                        Color = KEY_ACCENT, Transparency = 0.6,
                    }):Play()
                end)
                unlockBtn.Text = "Unlock"
                unlockBtn.BackgroundTransparency = 0.1
                checking = false
            end
        end)
    end

    unlockBtn.MouseButton1Click:Connect(tryValidate)
    keyInput.FocusLost:Connect(function(enterPressed)
        if enterPressed then tryValidate() end
    end)
end

