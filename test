        tween(bg, TWEEN_FAST, { BackgroundTransparency = math.max(0, (scheme.BgT or 0.15) - 0.1) })
        tween(stroke, TWEEN_FAST, { Transparency = math.max(0, (scheme.StrokeT or 0.35) - 0.15) })
