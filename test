                if following then
                    hudFollowDot.BackgroundColor3 = Color3.fromRGB(120, 180, 255)
                    local tName = FollowManager.Target.DisplayName or FollowManager.Target.Name or "?"
                    hudFollowLbl.Text = "→ " .. tostring(tName):sub(1, 14)
                    hudFollowLbl.TextColor3 = Color3.fromRGB(160, 210, 255)
                else
                    hudFollowDot.BackgroundColor3 = THEME.TextDim
                    hudFollowLbl.Text = "Follow: Off"
